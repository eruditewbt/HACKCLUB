# Engine
# Defaults assume you run from the `AUTOMATION/` directory:
# `cd AUTOMATION; python -m automation ...`
AUTO_ARTIFACTS_DIR=artifacts
AUTO_STATE_DIR=state
AUTO_LOG_LEVEL=INFO

# Default webhook for alerts
AUTO_WEBHOOK_URL_DEFAULT=

# External dependency (recommended for data_health workflows)
# Point this to: C:\Users\...\HACKCLUB\DATAANALYSIS
DATAANALYSIS_ROOT=
